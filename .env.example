# Copy this file to .env on the Azure VM and replace the placeholder values.

# Django
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-vm-dns-name.region.cloudapp.azure.com
CSRF_TRUSTED_ORIGINS=http://your-vm-dns-name.region.cloudapp.azure.com
FRONTEND_BASE_URL=http://your-vm-dns-name.region.cloudapp.azure.com
DATABASE_CONN_MAX_AGE=60

# The Nginx compose stack starts as HTTP-only. Set these to True after adding HTTPS.
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False

# PostgreSQL container
POSTGRES_DB=caseman
POSTGRES_USER=caseman
POSTGRES_PASSWORD=change-me-to-a-strong-database-password

# Optional startup behavior
RUN_MIGRATIONS=1
LOAD_DEV_SEED=0
